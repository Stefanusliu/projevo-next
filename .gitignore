# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# Firebase
firebase-debug.log*
firestore-debug.log*
ui-debug.log*
.firebase/
*-firebase-adminsdk-*.json

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# Security - Prevent secrets from being committed
*.log
*debug*.js
*test*.js
*test*.mjs
diagnostic.js
email-configs.js

# Firebase service account keys
*firebase*adminsdk*.json
firebase-private-key.json

# Setup and configuration files that might contain secrets
*SETUP*.md
*CONFIG*.md
*AUTH*.md
*SMS*.md
*PHONE*.md
*TEST*.md

# API keys and credentials
google-services.json
GoogleService-Info.plist
credentials.json
service-account-key.json

# Development and debug files
debug-*
test-*
create-test-*
browser-test-*

# Documentation with potential secrets
FIREBASE_*.md
SMS_*.md
PHONE_*.md
VENDOR_*.md
